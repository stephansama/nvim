{
	"$schema": "../schemas/plugin-keymap.json",
	"undotree": [
		["<leader>u", "<cmd>UndotreeToggle<CR>", { "desc": "UndotreeToggle" }]
	],
	"multicursors": [
		["<up>", "<cmd>lua require(\"multicursor-nvim\").lineAddCursor(-1)<CR>"],
		[
			"<leader><up>",
			"<cmd>lua require(\"multicursor-nvim\").lineSkipCursor(-1)<CR>"
		],
		["<down>", "<cmd>lua require(\"multicursor-nvim\").lineAddCursor(1)<CR>"],
		[
			"<leader><down>",
			"<cmd>lua require(\"multicursor-nvim\").lineSkipCursor(1)<CR>"
		],
		[
			"<leader>cn",
			"<cmd>lua require(\"multicursor-nvim\").matchAddCursor(1)<CR>"
		],
		[
			"<leader>cN",
			"<cmd>lua require(\"multicursor-nvim\").matchAddCursor(-1)<CR>"
		],
		[
			"<leader>cs",
			"<cmd>lua require(\"multicursor-nvim\").matchSkipCursor(1)<CR>"
		],
		[
			"<leader>cS",
			"<cmd>lua require(\"multicursor-nvim\").matchSkipCursor(-1)<CR>"
		]
	],
	"sidekick": [
		["<leader>aa", "<cmd>Sidekick cli toggle<CR>"],
		[
			"<C-.>",
			"<cmd>Sidekick cli focus<CR>",
			{ "desc": "Sidekick Switch Focus", "mode": "n,x,i,t" }
		],
		[
			"<leader>ap",
			"<cmd>Sidekick cli prompt<CR>",
			{ "desc": "Sidekick Select Prompt", "mode": "n,x" }
		],
		["<leader>as", "<cmd>Sidekick cli select<CR>"],
		[
			"<leader>at",
			"<cmd>lua require(\"sidekick.cli\").send({ msg = \"{this}\" })<CR>",
			{ "desc": "Send This", "mode": "n,x" }
		],
		[
			"<leader>av",
			"<cmd>lua require(\"sidekick.cli\").send({ msg = \"{selection}\" })<CR>",
			{ "desc": "Send Visual Selection", "mode": "x" }
		]
	],
	"neotest": [
		[
			"<C-\\>",
			"<cmd>Neotest summary<CR>",
			{ "desc": "Open neotest summary panel" }
		],
		[
			"<leader>rt",
			"<cmd>lua require('neotest').run.run(vim.fn.expand('%'))<CR>",
			{ "desc": "Neotest run all tests in current file" }
		],
		[
			"<leader>ro",
			"<cmd>Neotest output<CR>",
			{ "desc": "Open Neotest output" }
		],
		[
			"<leader>rp",
			"<cmd>Neotest output-panel<CR>",
			{ "desc": "Open Neotest output-panel" }
		]
	],
	"neo_tree": [
		["\\", "<cmd>Neotree filesystem toggle right<CR>"],
		["g\\", "<cmd>Neotree git_status toggle right<CR>"]
	],
	"outline": [["|", "<cmd>Outline<CR>", { "desc": "Toggle Outline" }]],
	"markdownpreview": [
		[
			"<leader>mp",
			"<cmd>MarkdownPreview<CR>",
			{ "desc": "Toggle Markdown Preview" }
		]
	],
	"todo_comments": [
		["<leader>tt", "<cmd>TodoFzfLua<CR>", { "desc": "Todo FzfLua" }]
	],
	"inlay_hints": [
		[
			"<leader>th",
			"<cmd>InlayHintsToggle<CR>",
			{ "desc": "Toggle inlay hints" }
		]
	],
	"treesitter_context": [
		[
			"<leader>ts",
			"<cmd>TSContext toggle<CR>",
			{ "desc": "Toggle treesitter context" }
		],
		[
			"[c",
			"<cmd>lua require('treesitter-context').go_to_context(vim.v.count1)<CR>",
			{
				"desc": "Go to treesitter context"
			}
		]
	],
	"urlview": [["<leader>gx", "<cmd>UrlView<CR>", { "desc": "Open urlview" }]],
	"startuptime": [
		[
			"<leader>st",
			"<cmd>StartupTime<CR>",
			{ "desc": "Debug neovim StartupTime" }
		]
	],
	"table_mode": [
		[
			"<leader>mt",
			"<cmd>TableModeToggle<CR>",
			{ "desc": "Toggle markdown table mode" }
		]
	],
	"maximizer": [
		[
			"<leader>sm",
			"<cmd>MaximizerToggle<CR>",
			{ "desc": "Toggle maximizer on a split" }
		]
	],
	"quicker": [
		[
			"<leader>q",
			"<cmd>lua require('quicker').toggle()<CR>",
			{ "desc": "Toggle quickfixlist" }
		]
	],
	"rest": [
		[
			"<leader>rr",
			"<cmd>Rest run<CR>",
			{ "desc": "Run rest command under cursor" }
		],
		[
			"<leader>rl",
			"<cmd>Rest last<CR>",
			{ "desc": "Run rest command under cursor" }
		],
		[
			"<leader>re",
			"<cmd>Rest env select_env<CR>",
			{ "desc": "Select environment variable for rest" }
		]
	],
	"liveserver": [
		[
			"<leader>ls",
			"<cmd>LiveServerToggle<CR>",
			{ "desc": "Toggle live server" }
		]
	],
	"grug_far": [
		[
			"<leader>S",
			"<cmd>lua require('grug-far').toggle_instance({ staticTitle = 'Find and Replace' })<CR>",
			{ "desc": "Toggle Grug Far" }
		],
		[
			"<leader>sw",
			"<cmd>lua require('grug-far').open({ prefills = { search = vim.fn.expand('<cword>') } })<CR>",
			{ "desc": "Search current word" }
		],
		[
			"<leader>sf",
			"<cmd>lua require('grug-far').open({ prefills = { paths = vim.fn.expand('%') } })<CR>",
			{ "desc": "Search current file" }
		]
	],
	"key_analyzer": [
		["<leader>ka", "<cmd>KeyAnalyzer ", { "desc": "Key Analyzer" }],
		[
			"<leader>kc",
			"<cmd>KeyAnalyzer <C-<CR>",
			{ "desc": "Key Analyzer for ctrl" }
		]
	],
	"gh_navigator": [
		["<leader>gF", "<cmd>GH repo<CR>", { "desc": "Open GitHub repo" }],
		[
			"<leader>gf",
			"<cmd>GH browse<CR>",
			{ "desc": "Open github file in blob view" }
		],
		[
			"<leader>gP",
			"<cmd>GH repo pulls",
			{ "desc": "Open github repo pull requests" }
		]
	],
	"tmux": [
		["<C-h>", "<cmd>TmuxNavigateLeft<CR>"],
		["<C-j>", "<cmd>TmuxNavigateDown<CR>"],
		["<C-k>", "<cmd>TmuxNavigateUp<CR>"],
		["<C-l>", "<cmd>TmuxNavigateRight<CR>"]
	],
	"crates": [
		[
			"<leader>cs",
			"<cmd>Crates show_popup<CR>",
			{ "desc": "Crates.nvim open features list" }
		],
		[
			"<leader>cu",
			"<cmd>Crates update_crates<CR>",
			{ "desc": "Crates.nvim update crates" }
		],
		[
			"<leader>ch",
			"<cmd>Crates open_homepage<CR>",
			{ "desc": "Crates.nvim open homepage" }
		],
		[
			"<leader>cc",
			"<cmd>Crates open_cratesio<CR>",
			{ "desc": "Crates.nvim open crates.io" }
		],
		[
			"<leader>cr",
			"<cmd>Crates open_repository<CR>",
			{ "desc": "Crates.nvim open repository" }
		],
		[
			"<leader>cd",
			"<cmd>Crates open_documentation<CR>",
			{ "desc": "Crates.nvim open docs.rs" }
		],
		[
			"<leader>cf",
			"<cmd>Crates show_features_popup<CR>",
			{ "desc": "Crates.nvim open features list" }
		],
		[
			"<leader>ce",
			"<cmd>Crates show_dependencies_popup<CR>",
			{ "desc": "Crates.nvim open dependencies list" }
		]
	],
	"leetcode": [
		["<leader>le", "<cmd>Leet<CR>", { "desc": "Open Leet" }],
		["<leader>lr", "<cmd>Leet run<CR>", { "desc": "Run leet" }],
		["<leader>lp", "<cmd>Leet open<CR>"],
		["<leader>li", "<cmd>Leet info<CR>", { "desc": "Leet info" }],
		[
			"<leader>lc",
			"<cmd>Leet lang<CR>",
			{ "desc": "Open leet language picker" }
		],
		[
			"<leader>lh",
			"<cmd>lua vim.fn.jobstart({ 'open', 'https://github.com/kawre/leetcode.nvim?tab=readme-ov-file' })<CR>",
			{ "desc": "Open leet.nvim readme" }
		]
	],
	"fzf_tmux_runner": [
		[
			"<leader>fm",
			"<cmd>FzfTmuxMake<CR>",
			{ "desc": "launch makefile target" }
		],
		[
			"<leader>fj",
			"<cmd>FzfTmuxPackageJson<CR>",
			{ "desc": "launch package json script" }
		]
	],
	"fzf_lua": [
		["<leader>ff", "<cmd>FzfLua files<CR>", { "desc": "Find files" }],
		["<leader>f`", "<cmd>FzfLua marks<CR>", { "desc": "Find marks" }],
		["<leader>fw", "<cmd>FzfLua live_grep<CR>", { "desc": "Find word" }],
		["<leader>fk", "<cmd>FzfLua keymaps<CR>", { "desc": "Find keymaps" }],
		["<leader>fo", "<cmd>FzfLua oldfiles<CR>", { "desc": "Find oldfiles" }],
		["<leader>fe", "<cmd>FzfLua grep_cword<CR>", { "desc": "Find exact word" }],
		["<leader><Tab>", "<cmd>FzfLua tabs<CR>", { "desc": "Find tabs" }],
		[
			"<leader>gss",
			"<cmd>FzfLua git_status<CR>",
			{ "desc": "Find within git status" }
		],
		[
			"<leader>fs",
			"<cmd>FzfLua grep_curbuf<CR>",
			{ "desc": "Find within current buffer" }
		],
		[
			"<leader>fl",
			"<cmd>FzfLua resume<CR>",
			{ "desc": "Resume last fzf search" }
		]
	],
	"laravel": [
		["<leader>la", "<cmd>Laravel artisan<cr>"],
		["<leader>lr", "<cmd>Laravel routes<cr>"],
		["<leader>lt", "<cmd>Laravel related<cr>"]
	]
}
