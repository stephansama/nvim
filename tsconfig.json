{
	"include": [
		"./scripts/*.ts",
		"./scripts/schemas/*.ts",
		"eslint.config.ts",
		"lua/**/*.ts",
		"lua/**/*.json"
	],
	"compilerOptions": {
		"moduleResolution": "bundler",
		"lib": ["DOM", "ESNext"],
		"paths": {
			"*": ["./lua/*"],
			"~/*": ["./*"],
			"@/*": ["./lua/*"]
		},
		"composite": true,
		"resolveJsonModule": true,
		"types": [
			"lua-types/5.1",
			"@gkzhb/lua-types-nvim",
			"./lua/vim.d.ts",
			"node"
		]
	}
}
