{
	"name": "nvim",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"prebuild": "pnpm run scripts:modes",
		"build": "tstl -p ./tsconfig.lua.json",
		"postbuild": "pnpm run scripts:clean",
		"dev": "tstl -p ./tsconfig.lua.json --watch",
		"fmt:check": "prettier . --check",
		"fmt:write": "prettier . --write",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"prepare": "pnpm run scripts:modes && pnpm run scripts:build",
		"scripts:bloat": "tsx ./scripts/bloat.ts",
		"scripts:build": "tsx ./scripts/build.ts",
		"scripts:clean": "tsx ./scripts/clean.ts",
		"scripts:merge": "tsx ./scripts/merge.ts",
		"scripts:modes": "tsx ./scripts/modes.ts"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"nano-staged": {
		"*": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"prettier": {
		"plugins": [
			"prettier-plugin-organize-imports",
			"prettier-plugin-packagejson",
			"@prettier/plugin-lua"
		],
		"quoteProps": "consistent",
		"overrides": [
			{
				"files": "nvim-pack-lock.json",
				"options": {
					"useTabs": false
				}
			}
		]
	},
	"devDependencies": {
		"@commitlint/cli": "catalog:",
		"@commitlint/config-conventional": "catalog:",
		"@eslint/json": "catalog:",
		"@eslint/markdown": "catalog:",
		"@gkzhb/lua-types-nvim": "catalog:",
		"@prettier/plugin-lua": "catalog:",
		"@stephansama/eslint-config": "catalog:",
		"@types/node": "catalog:",
		"eslint": "catalog:",
		"eslint-plugin-jsonc": "catalog:",
		"eslint-plugin-zod": "catalog:",
		"globals": "catalog:",
		"lefthook": "catalog:",
		"lua-types": "catalog:",
		"nano-staged": "catalog:",
		"prettier": "catalog:",
		"prettier-plugin-organize-imports": "catalog:",
		"prettier-plugin-packagejson": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"typescript-to-lua": "catalog:",
		"zod": "catalog:"
	},
	"engines": {
		"node": ">=24"
	}
}
